root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
indent_style = space
trim_trailing_whitespace = true

[*.cs]
indent_size = 4
# File-scoped namespaces, consistent with repo conventions (not build-enforced here).
csharp_style_namespace_declarations = file_scoped:suggestion

[*.{md,json,props,csproj,sln}]
indent_size = 2
